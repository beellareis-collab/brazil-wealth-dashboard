# Copie este arquivo como .env.local e preencha com suas credenciais
# Encontre os valores em: Supabase → Project Settings → API

# Supabase principal (clientes, onboarding, cobranças, etc.)
REACT_APP_SUPABASE_URL=https://SEU_PROJETO_PRINCIPAL.supabase.co
REACT_APP_SUPABASE_ANON_KEY=sua_anon_key_principal

# Supabase RD Station (tabela bw_deals — pipeline)
REACT_APP_SUPABASE_URL_RD=https://SEU_PROJETO_RD.supabase.co
REACT_APP_SUPABASE_ANON_KEY_RD=sua_anon_key_rd
